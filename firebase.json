{
  "hosting": [
    {
      "target": "app",
      "public": "web-portal/dist-web",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        {
          "source": "assets/**",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        }
      ]
    },
    {
      "target": "site",
      "public": "landing",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    }
  ]
}
